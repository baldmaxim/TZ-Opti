# Корневой .env.example
# Сервер
PORT=4000
NODE_ENV=development
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Supabase Postgres. В дашборде Supabase: Project → Connect → "URI".
# Замените <password> на реальный пароль БД (URL-encode спецсимволы).
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Клиент
VITE_API_BASE=/api
